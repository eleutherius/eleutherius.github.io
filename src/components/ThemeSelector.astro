---
const themes = [
  "light",
  "dark",
  "lofi",
  "synthwave",
];
---

<div title="Change Theme" class="dropdown dropdown-end" id="theme-selector">
  <button type="button" tabindex="0" class="btn btn-ghost gap-1 normal-case" aria-label="Change theme">
    <svg
      width="20"
      height="20"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      class="inline-block h-5 w-5 stroke-current md:h-6 md:w-6"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M7 21a4 4 0 0 1-4-4V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v12a4 4 0 0 1-4 4Zm0 0h12a2 2 0 0 0 2-2v-4a2 2 0 0 0-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 0 1 2.828 0l2.829 2.829a2 2 0 0 1 0 2.828l-8.486 8.485M7 17h.01"
      ></path>
    </svg>
    <span class="hidden md:inline">Theme</span>
    <svg
      width="12"
      height="12"
      class="ml-1 hidden h-3 w-3 fill-current opacity-60 sm:inline-block"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 2048 2048"
    >
      <path d="M1799 349 2041 590 1024 1607 7 590l242-241 775 775 775-775Z"></path>
    </svg>
  </button>

  <div
    tabindex="0"
    class="dropdown-content z-50 mt-3 h-[70vh] max-h-96 w-56 overflow-y-auto rounded-box bg-base-200 p-3 text-base-content shadow-2xl"
  >
    <div class="grid grid-cols-1 gap-2">
      {
        themes.map((theme) => (
          <button
            type="button"
            class="overflow-hidden rounded-lg outline-2 outline-offset-2"
            data-set-theme={theme}
            aria-label={`Use ${theme} theme`}
          >
            <div data-theme={theme} class="w-full cursor-pointer bg-base-100 text-base-content">
              <div class="flex items-center gap-2 px-4 py-3">
                <div class="grow text-left text-sm font-bold">{theme}</div>
                <div class="flex h-5 shrink-0 gap-1">
                  <span class="w-2 rounded bg-primary"></span>
                  <span class="w-2 rounded bg-secondary"></span>
                  <span class="w-2 rounded bg-accent"></span>
                  <span class="w-2 rounded bg-neutral"></span>
                </div>
              </div>
            </div>
          </button>
        ))
      }
    </div>
  </div>
</div>

<script define:vars={{ themes }}>
const themeStorageKey = "astrofy-theme";
const defaultTheme = "lofi";

function getStoredTheme() {
  try {
    const theme = localStorage.getItem(themeStorageKey);
    return themes.includes(theme) ? theme : defaultTheme;
  } catch {
    return defaultTheme;
  }
}

function markActiveTheme(theme) {
  document.querySelectorAll("#theme-selector [data-set-theme]").forEach((button) => {
    button.classList.toggle("outline", button.dataset.setTheme === theme);
    button.classList.toggle("outline-base-content", button.dataset.setTheme === theme);
  });
}

function setTheme(theme) {
  document.documentElement.setAttribute("data-theme", theme);
  try {
    localStorage.setItem(themeStorageKey, theme);
  } catch {}
  markActiveTheme(theme);
}

function initThemeSelector() {
  const theme = getStoredTheme();
  setTheme(theme);

  document.querySelectorAll("#theme-selector [data-set-theme]").forEach((button) => {
    button.addEventListener("click", () => {
      setTheme(button.dataset.setTheme);
    });
  });
}

document.addEventListener("astro:page-load", initThemeSelector);
initThemeSelector();
</script>
