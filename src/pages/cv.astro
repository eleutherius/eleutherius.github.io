---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Profile</div>
  </div>

  <div class="mb-10 text-justify">
    Platform-focused DevOps Engineer with 6+ years of experience designing and automating scalable
    infrastructure and internal developer platforms. Specialized in building self-service systems,
    improving developer experience, and reducing operational overhead through Infrastructure as Code,
    GitOps, and automation. Strong background in Kubernetes, AWS, CI/CD, and system reliability.
    My goal is to automate complex processes and make life easier.
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="Specialist's Academic Level — Radio Electronic Devices and Facilities"
      subtitle="2016 at National Technical University of Ukraine «Kyiv Polytechnic Institute», Kyiv, Ukraine"
    />
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="DevOps Engineer / Senior Platform Engineer"
      subtitle="December 2021 — Present at JCI"
    >
      <ul class="list-disc mx-6 mb-2 grid gap-1">
        <li>Designed and implemented reusable infrastructure modules using Terraform and Ansible, enabling faster environment provisioning across teams.</li>
        <li>Backend development (GraphQL) for internal DevOps tools.</li>
        <li>Built standardized CI/CD pipelines, reducing deployment time and minimizing manual errors across multiple teams.</li>
        <li>Developed automation scripts in Python, Go, and Bash for Linux environments (CentOS, Debian, AlmaLinux).</li>
        <li>Managed HashiCorp Vault for secrets management and security compliance.</li>
        <li>Maintained Linux servers, troubleshooting production incidents and optimizing performance.</li>
        <li>Designed and maintained Kubernetes-based platform using GitOps (ArgoCD), enabling self-service deployments.</li>
        <li>Implemented observability stack (Prometheus, Grafana, Zabbix) for monitoring and alerting.</li>
      </ul>
      <p class="font-semibold mt-2 mb-1">Achievements:</p>
      <ul class="list-disc mx-6 grid gap-1">
        <li>Migrated legacy internal product from Django 1.8 to modern Django + GraphQL architecture.</li>
        <li>Successfully migrated legacy redundancy mechanism to restore nodes using ZFS restore mechanisms.</li>
        <li>Improved system reliability by implementing monitoring and log forwarding best practices.</li>
        <li>Implemented internal ACME server for automated certificate management across infrastructure.</li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="QA Performance Engineer"
      subtitle="July 2019 — December 2021 at JCI"
    >
      <ul class="list-disc mx-6 mb-2 grid gap-1">
        <li>Conducted load and performance testing for REST APIs and large-scale applications.</li>
        <li>Used Locust and custom Python frameworks to simulate traffic and monitor system bottlenecks.</li>
      </ul>
      <p class="font-semibold mt-2 mb-1">Achievements:</p>
      <ul class="list-disc mx-6 grid gap-1">
        <li>Identified key performance issues that improved system throughput by 25%.</li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="QA Engineer"
      subtitle="December 2018 — July 2019 at JCI"
    >
      <ul class="list-disc mx-6 grid gap-1">
        <li>Tested IoT server applications for security devices.</li>
        <li>Wrote HLD documentation and maintained test cases in TestRail.</li>
        <li>Automated tests with Python; integrated with Redis, Nginx, MySQL.</li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="Linux Administrator / DevOps"
      subtitle="April 2018 — December 2019 at Softevol"
    >
      <ul class="list-disc mx-6 grid gap-1">
        <li>Managed Linux servers and virtualization (VMware ESXi, vSphere, vCenter).</li>
        <li>Configured SSL (Comodo, Let's Encrypt), MySQL (MariaDB, Percona cluster).</li>
        <li>Optimized websites for Google PageSpeed performance.</li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="Network Engineer"
      subtitle="June 2014 — April 2018 at IC-LINE UA"
    >
      <ul class="list-disc mx-6 grid gap-1">
        <li>Configured and maintained network equipment (Cisco, Huawei, ZTE, BDCOM).</li>
        <li>Designed and deployed PON networks, including CWDM/DWDM solutions.</li>
        <li>Implemented monitoring with Zabbix and Userside.</li>
      </ul>
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>

  <ul class="list-disc md:columns-3 columns-2 mx-6 mb-10">
    <li>Python</li>
    <li>Go</li>
    <li>Bash</li>
    <li>Terraform</li>
    <li>Ansible</li>
    <li>Kubernetes</li>
    <li>ArgoCD</li>
    <li>Jenkins</li>
    <li>GitLab CI</li>
    <li>Linux</li>
    <li>Prometheus</li>
    <li>Grafana</li>
    <li>Zabbix</li>
    <li>HashiCorp Vault</li>
    <li>GraphQL</li>
    <li>Django</li>
    <li>Nginx</li>
    <li>AWS (S3, EC2, IAM)</li>
    <li>Docker</li>
    <li>Okta</li>
    <li>Cisco CLI</li>
    <li>ACME / Certbot</li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Languages</div>
  </div>

  <ul class="list-disc mx-6 mb-10">
    <li>Ukrainian — Fluent</li>
    <li>Russian — Fluent</li>
    <li>English — Upper-Intermediate</li>
  </ul>
</BaseLayout>
